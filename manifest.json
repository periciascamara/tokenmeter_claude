{
  "manifest_version": 3,
  "name": "TokenMeter - Claude.ai Token Tracker",
  "version": "1.0.0",
  "description": "Visualiza o uso de tokens por sessão e semanal, indicando o modelo utilizado e custos estimados em Reais (R$) no Claude.ai.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://claude.ai/*"
      ],
      "js": [
        "utils.js",
        "content.js"
      ],
      "css": [
        "popup.css"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://claude.ai/*"
      ],
      "js": [
        "inject.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "inject.js"
      ],
      "matches": [
        "https://claude.ai/*"
      ]
    }
  ]
}
